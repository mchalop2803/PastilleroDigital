<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="activities.AddFamilyActivity">

    <LinearLayout
        android:layout_width="409dp"
        android:layout_height="729dp"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp"
        tools:ignore="MissingConstraints">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E4E4E4"
        tools:ignore="MissingConstraints">

        <ImageButton
            android:id="@+id/imageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_back"
            android:layout_marginTop="10dp"
            android:layout_marginStart="10dp"
            android:backgroundTint="@color/grey_light"/>

        <TextView
            android:id="@+id/tvFamilyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/family_title"
            android:textStyle="bold"
            android:layout_weight="2"
            android:textSize="30sp"
            android:textColor="@color/black"
            android:textAlignment="center"
            android:layout_margin="10dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="60dp"
        android:layout_weight="1"
        app:endIconMode="clear_text"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:textColorHint="@color/gray_medium"
        app:helperText="required"
        app:helperTextTextColor="#706F6F">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/textInputEditTextFamilyName"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:inputType="text"
            android:enabled="true"
            android:hint="@string/family_name" />
    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="60dp"
        android:layout_weight="1"
        app:endIconMode="clear_text"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:textColorHint="@color/gray_medium"
        app:helperText="required"
        app:helperTextTextColor="#706F6F">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/textInputEditTextFamilyPhone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:inputType="text"
            android:enabled="true"
            android:hint="@string/family_phone" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="60dp"
        android:layout_weight="1"
        app:endIconMode="clear_text"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:textColorHint="@color/gray_medium"
        app:helperText="required"
        app:helperTextTextColor="#706F6F">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/textInputEditTextFamilyRelation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:inputType="text"
            android:enabled="true"
            android:hint="@string/family_relation" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnAddFamily"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/blue_primary"
        android:textSize="30sp"
        android:layout_marginTop="40dp"
        android:layout_gravity="center"
        android:text="@string/add_family" />

    </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>